# ═══ Hyperion Configuration ═══

# ── Server ──
PORT=3333

# ── Security ──
CORS_ORIGIN=                    # Allowed CORS origin (blank = disabled)
CSP_ENABLED=false               # Content-Security-Policy header
API_RATE_LIMIT=100              # Max API requests per minute per IP

# ── AI / LLM ──
LLM_PROVIDERS=ollama            # Comma-separated priority: ollama,openai,gemini
LLM_API_KEY=                    # Fallback API key for all providers
LLM_MODEL=                      # Override default model for active provider
LLM_BASE_URL=http://localhost:11434  # Ollama base URL
OPENAI_API_KEY=                 # OpenAI-specific key
GEMINI_API_KEY=                 # Gemini-specific key
OLLAMA_MODEL=llama3             # Ollama model override
OPENAI_MODEL=gpt-4o-mini       # OpenAI model override
GEMINI_MODEL=gemini-2.0-flash  # Gemini model override

# ── MCP (Model Context Protocol) ──
MCP_ENABLED=false
MCP_PORT=3334

# ── Discovery ──
DISCOVERY_ENABLED=false

# ── Logging ──
LOG_LEVEL=info                  # debug, info, warn, error
LOG_FILE=false                  # Write logs to data/hyperion.log
